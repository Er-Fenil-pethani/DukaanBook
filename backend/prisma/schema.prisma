generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  password          String
  name              String
  role              Role             @default(CASHIER)
  suspended         Boolean          @default(false)
  businessProfileId String?
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  sales             Sale[]
  stockMovements    StockMovement[]
  auditLogs         AuditLog[]
  createdAt         DateTime         @default(now())

  @@index([role])
  @@index([email])
  @@index([businessProfileId])
}

enum Role {
  OWNER
  CASHIER
}

model BusinessProfile {
  id         String      @id @default(uuid())
  name       String
  address    String?
  phone      String?
  currency   String      @default("PKR")
  taxRate    Decimal     @db.Decimal(5, 2) @default(0)
  logoUrl    String?
  users      User[]
  categories Category[]
  products   Product[]
  sales      Sale[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Category {
  id                String          @id @default(uuid())
  name              String
  slug              String
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  products          Product[]
  createdAt         DateTime        @default(now())

  @@unique([businessProfileId, name])
  @@unique([businessProfileId, slug])
  @@index([businessProfileId])
}

model Product {
  id                String          @id @default(uuid())
  sku               String
  barcode           String?
  name              String
  description       String?         @db.Text
  price             Decimal         @db.Decimal(10, 2)
  costPrice         Decimal         @db.Decimal(10, 2)
  stock             Int             @default(0)
  lowStockThreshold Int             @default(10)

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  categoryId        String
  category          Category        @relation(fields: [categoryId], references: [id])

  imageUrl          String?
  active            Boolean         @default(true)

  stockMovements    StockMovement[]
  saleItems         SaleItem[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([businessProfileId, sku])
  @@unique([businessProfileId, barcode])
  @@index([businessProfileId])
  @@index([categoryId])
  @@index([active, stock])
}

model StockMovement {
  id        String            @id @default(uuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockMovementType
  quantity  Int
  reason    String
  notes     String?
  actorId   String
  actor     User              @relation(fields: [actorId], references: [id])
  createdAt DateTime          @default(now())

  @@index([productId, createdAt])
  @@index([type])
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
}

model Sale {
  id                String          @id @default(uuid())
  saleNumber        String

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  cashierId         String
  cashier           User            @relation(fields: [cashierId], references: [id])

  items             SaleItem[]

  subtotal          Decimal         @db.Decimal(10, 2)
  taxAmount         Decimal         @db.Decimal(10, 2)
  total             Decimal         @db.Decimal(10, 2)

  paymentMethod     PaymentMethod
  status            SaleStatus      @default(COMPLETED)

  refundedAt        DateTime?
  refundReason      String?
  createdAt         DateTime        @default(now())

  @@unique([businessProfileId, saleNumber])
  @@index([businessProfileId])
  @@index([cashierId, createdAt])
  @@index([status])
  @@index([createdAt])
}

enum SaleStatus {
  COMPLETED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
}

model SaleItem {
  id           String  @id @default(uuid())

  saleId       String
  sale         Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId    String
  product      Product @relation(fields: [productId], references: [id])

  productName  String
  productPrice Decimal @db.Decimal(10, 2)
  quantity     Int
  lineTotal    Decimal @db.Decimal(10, 2)

  @@index([saleId])
  @@index([productId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}